{
    "name": "byte5/ai-entries-chatbot",
    "description": "Statamic addon for AI-powered chatbot using entry embeddings.",
    "license": "GPL-3.0-or-later",
    "type": "statamic-addon",
    "autoload": {
        "psr-4": {
            "Byte5\\AiEntriesChatbot\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Byte5\\AiEntriesChatbot\\Tests\\": "tests"
        }
    },
    "authors": [
        {
            "name": "byte5 GmbH",
            "email": "info@byte5.de"
        }
    ],
    "require": {
        "php": "^8.3",
        "statamic/cms": "^6.0",
        "laravel/ai": "^0.3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.8",
        "driftingly/rector-laravel": "^2.2",
        "rector/rector": "^2.3",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29"
    },
    "config": {
        "allow-plugins": {
            "pixelfear/composer-dist-plugin": true
        }
    },
    "extra": {
        "statamic": {
            "name": "AI Entries Chatbot",
            "description": "AI-powered chatbot using entry embeddings"
        },
        "laravel": {
            "providers": [
                "Byte5\\AiEntriesChatbot\\ServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}